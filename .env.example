POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=transcendence
DATABASE_URL="postgresql://your_user:your_password@db:5432/transcendence?schema=public"

# Backend
NODE_ENV=development
PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=2592000
LOG_LEVEL=debug

# Frontend URL used by backend emails
FRONTEND_URL=https://localhost:8443

# SMTP Gmail (production-like)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false

# Frontend (si utilisé)
VITE_API_URL=https://localhost:8443/api
VITE_WS_URL=wss://localhost:8443/socket.io
FRONTEND_URL=https://localhost:8443

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your.gmail@gmail.com

# Redis (optionnel pour sessions/cache)
REDIS_URL=redis://redis:6379

# Logs
LOG_LEVEL=debug
